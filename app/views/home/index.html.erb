<% content_for :title, "Hands" %>
<% content_for :app_icon, "✋" %>
<% content_for :app_title, "Hands" %>
<% content_for :app_subtitle, current_user.display_name if logged_in? %>
<% content_for :no_header, true unless logged_in? %>

<% if logged_in? %>
  <nav class="mini-app-body" aria-label="Main menu">
    <ul class="menu" role="list" data-controller="menu">
      <% @domains.each do |domain| %>
        <li><%= link_to domain.name, domain_root_path(domain.slug) %></li>
      <% end %>

      <% if @domains.none? %>
        <li class="menu-message">You are not a member of any course domain yet.</li>
      <% end %>

    </ul>
  </nav>
  <div class="mini-app-footer">
    <% if current_user.admin? %>
        <%= link_to "Manage domains", admin_course_domains_path, class: "action" %>
    <% end %>

    <%= button_to "Sign out", logout_path, method: :delete, class: "action text-danger",
          form: { data: { turbo_confirm: "Sign out?" } } %>
  </div>
<% else %>
  <div class="mini-app-body hands-app home-page">
    <div class="home-hero">
      <div class="home-hero-emoji">✋</div>
      <h5>Ask questions and get<br> help in class.</h5>
    </div>
  </div>
  <div class="mini-app-footer">
    <%= link_to "Sign in", auth_mail_login_path, class: "btn btn-primary w-100" %>
  </div>
<% end %>
