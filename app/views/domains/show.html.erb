<% content_for :title, @course_domain.name %>
<% content_for :app_icon, "✋" %>
<% content_for :app_title, @course_domain.name %>
<% content_for :app_subtitle, acting_staff? ? "Staff" : "Assistance" %>

<% if current_membership || acting_staff? %>
  <nav class="mini-app-body" aria-label="<%= @course_domain.name %> menu">
    <ul class="menu" role="list" data-controller="menu">
      <% if current_membership %>
        <li><%= link_to "Ask a question", domain_hand_path(@course_domain.slug) %></li>
      <% end %>

      <% if acting_staff? %>
        <li><%= link_to "Open the queue", domain_queue_hands_path(@course_domain.slug) %></li>
        <li><%= link_to "All students", domain_attendance_path(@course_domain.slug) %></li>
        <li><%= link_to "Recent notes", domain_notes_path(@course_domain.slug) %></li>
        <% if acting_senior? %>
          <li><%= link_to "Manage staff", domain_staff_path(@course_domain.slug) %></li>
        <% end %>
      <% end %>
    </ul>
  </nav>
<% else %>
  <div class="mini-app-body hands-app">
    <div class="message">
      <% if @course_domain.enrollment_open? %>
        <h5>You are not a member of<br><%= @course_domain.name %> yet.</h5>
      <% else %>
        <h5>Enrollment is closed.<br><small class="text-body-secondary">Use the widget in your course site, or ask a teacher.</small></h5>
      <% end %>
    </div>
    <% if @course_domain.enrollment_open? %>
      <div class="d-grid">
        <%= button_to "Join #{@course_domain.name}", domain_join_path(@course_domain.slug), method: :post, class: "btn btn-primary w-100" %>
      </div>
    <% end %>
  </div>
<% end %>
