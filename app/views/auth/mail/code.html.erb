<div class="mini-app-body hands-app">
  <h2 class="h5 mb-3">Enter your code</h2>
  <p class="text-muted">We sent a 6-character code to <strong><%= session[:login_email] %></strong>.</p>

  <%= form_with url: auth_mail_validate_path, method: :post do |f| %>
    <div class="mb-3">
      <%= f.label :code, "Sign-in code" %>
      <%= f.text_field :code, required: true, autofocus: true,
            inputmode: "text", autocomplete: "one-time-code", maxlength: 6 %>
    </div>
    <%= f.submit "Sign in", class: "btn btn--primary" %>
    <%= link_to "Start over", auth_mail_login_path, class: "btn" %>
  <% end %>
</div>
