/* Student-facing hands widget — ported from course-site's assistance.scss, made
   self-contained (no Bootstrap) so it renders identically inside a Shadow DOM on
   any host page. Everything is scoped under .hands-widget. */

.hands-widget {
    width: 300px;
    max-width: 100%;
    box-sizing: border-box;
    padding: 0.75rem;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 1rem;
    line-height: 1.5;
    color: #212529;
}

.hands-widget *, .hands-widget *::before, .hands-widget *::after { box-sizing: border-box; }

.hands-widget p,
.hands-widget textarea,
.hands-widget input,
.hands-widget img { margin-bottom: 0.5rem; }

.hands-widget .cards { display: block; }

/* Labels: the bold heading is hidden in the compact popup (as in the original),
   leaving just the small instruction line. */
.hands-widget label {
    display: block;
    font-size: smaller;
}
.hands-widget label strong { display: none; }

.hands-widget textarea { height: 8rem; }

.hands-widget .form-control {
    display: block;
    width: 100%;
    padding: 0.375rem 0.75rem;
    font-size: 1rem;
    line-height: 1.5;
    color: #212529;
    background-color: #fff;
    border: 1px solid #ced4da;
    border-radius: 0.375rem;
    outline: none;
}
.hands-widget .form-control:focus { border-color: #ffc107; box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25); }

/* Signature yellow, full-width buttons. */
.hands-widget .btn {
    display: inline-block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    color: #000;
    background-color: #ffc107;
    border: 1px solid #ffc107;
    border-radius: 0.375rem;
    cursor: pointer;
}
.hands-widget .btn:hover { background-color: #e0a800; border-color: #d39e00; }

.hands-widget .d-grid { display: grid; }

.hands-widget #waiting-gif {
    width: 100%;
    display: block;
    /* max-height: 180px; */
    object-fit: contain;
    border-radius: 0.375rem;
}

.hands-widget .message { text-align: center; }
.hands-widget .message.big {
    margin-top: 1rem;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
}

.hands-widget .text-center { text-align: center; }
.hands-widget .small { font-size: 85%; color: #6c757d; }
.hands-widget .mt-3 { margin-top: 1rem; }

/* Check-in ("location") view — the yellow rounded box with a big dotted field,
   scaled down from course-site's mini-app version to fit the popup. */
.hands-widget #location-form {
    background-color: rgba(255, 206, 0, 0.6);
    border-radius: 20px;
    padding: 1.25rem;
    text-align: center;
}
.hands-widget #location-form label { display: block; margin-bottom: 0.35rem; }
.hands-widget #location-form #location-text-field {
    border: none;
    border-bottom: 2px dotted;
    border-radius: 0;
    background: transparent;
    font-size: 1.5rem;
    text-align: center;
    width: 100%;
    margin: 0 auto 0.75rem;
}
