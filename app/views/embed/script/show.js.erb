// Hands embed widget loader — served by the hands app, loaded by a linked
// course-site with:
//   <div id="hands-embed-widget"></div>
//   <script>window.HandsEmbed = { tokenUrl, handsUrl, mount };</script>
//   <script src="{handsUrl}/embed/widget.js" async></script>
//
// It never sees the shared secret: it asks course-site (same origin) for a
// short-lived signed token and uses it to talk to the hands app cross-origin.
// A tiny inlined Action Cable client keeps the widget live and records presence.
(function () {
    "use strict";
    if (window.__handsEmbedStarted) return;
    var cfg = window.HandsEmbed;
    if (!cfg || !cfg.handsUrl || !cfg.tokenUrl) return;

    var mount = document.querySelector(cfg.mount || "#hands-embed-widget");
    if (!mount) return;
    window.__handsEmbedStarted = true;

    var handsBase = String(cfg.handsUrl).replace(/\/+$/, "");
    var waitingGifObjectUrl = null;
    var waitingGifPromise = null;

    // Render inside a Shadow DOM so the widget's own stylesheet (served by the
    // hands app) fully controls its look, isolated from the host page's CSS.
    var shadow = mount.shadowRoot || mount.attachShadow({ mode: "open" });
    shadow.innerHTML =
        '<link rel="stylesheet" href="' + handsBase + '/embed/widget.css">' +
        '<div class="hands-widget" id="hands-embed-content"></div>';
    var content = shadow.getElementById("hands-embed-content");

    // Focus the question field when the dropdown is opened (Bootstrap event; a
    // no-op if the host isn't using a Bootstrap dropdown).
    var dropdown = mount.closest(".dropdown");
    if (dropdown) dropdown.addEventListener("shown.bs.dropdown", focusQuestion);

    function focusQuestion() {
        var el = content.querySelector("[autofocus], textarea, input[type=text]");
        if (el) el.focus();
    }

    // Each hands-app request/connection gets its own fresh token (single-use nonce).
    function freshToken() {
        return fetch(cfg.tokenUrl, { headers: { Accept: "application/json" }, credentials: "same-origin" })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (c) { return c && c.token; })
            .catch(function () { return null; });
    }

    function render(html) {
        content.innerHTML = html;
        bindForms();
        setupWaitingGif();
        focusQuestion(); // no-op while the dropdown is closed / field hidden
        publishState();
    }

    // Tell the host page what we are showing. The state marker is inside the
    // Shadow DOM, where the host cannot see it, so mirror it onto the mount
    // element and fire an event there. "attention" means the student cannot ask
    // anything until they give us something (a location check-in) — hosts use it
    // to pop their menu open unprompted, but whether interrupting is appropriate
    // is theirs to decide, not ours.
    function publishState() {
        var marker = content.querySelector('meta[name="hands-state"]');
        var state = marker ? marker.getAttribute("content") : "";
        var attention = !!marker && marker.dataset.attention === "true";

        mount.dataset.handsState = state;
        mount.dataset.handsAttention = attention ? "true" : "false";
        mount.dispatchEvent(new CustomEvent("hands:state", {
            bubbles: true,
            detail: { state: state, attention: attention }
        }));
    }

    // The fragment's forms point at the hands app's standalone routes; intercept
    // them and call the token-authed embed API instead.
    function bindForms() {
        content.querySelectorAll("form").forEach(function (form) {
            form.addEventListener("submit", function (e) { submitForm(e, form); }, { once: true });
        });
    }

    // Random waiting GIF, remembered across polls (as course-site did). The
    // gif is stored in the repo XOR-obfuscated so it isn't visible as-is on
    // GitHub; decode it here into a Blob and show that instead.
    //
    // render() can fire twice in quick succession (a cable push racing a form
    // submit's response), each replacing content's innerHTML and thus the
    // #waiting-gif node. Decoding is shared across calls via waitingGifPromise,
    // and the resolved URL is applied to whichever #waiting-gif element is
    // current *when it resolves* rather than one captured up front, so a
    // stale/detached element from an earlier render() never ends up as the one
    // holding the blob src.
    function setupWaitingGif() {
        var img = content.querySelector("#waiting-gif");
        if (!img) return;
        img.onerror = function () { img.style.display = "none"; };

        if (waitingGifObjectUrl) { img.src = waitingGifObjectUrl; return; }

        if (!waitingGifPromise) {
            waitingGifPromise = decodeWaitingGif(img).catch(function (e) { waitingGifPromise = null; throw e; });
        }

        waitingGifPromise.then(function (url) {
            waitingGifObjectUrl = url;
            var currentImg = content.querySelector("#waiting-gif");
            if (currentImg) currentImg.src = url;
        }).catch(function () {
            var currentImg = content.querySelector("#waiting-gif");
            if (currentImg) currentImg.style.display = "none";
        });
    }

    function decodeWaitingGif(img) {
        var urls = JSON.parse(img.dataset.waitingGifUrls || "[]");
        if (urls.length === 0) return Promise.reject(new Error("no waiting gif urls"));

        var chosen = localStorage["hands-waiting-gif"];
        if (!chosen || urls.indexOf(chosen) === -1) {
            chosen = urls[Math.floor(Math.random() * urls.length)];
            localStorage["hands-waiting-gif"] = chosen;
        }

        var key = img.dataset.waitingGifKey.match(/../g).map(function (h) { return parseInt(h, 16); });
        return fetch(chosen).then(function (res) {
            if (!res.ok) throw new Error("fetch failed");
            return res.arrayBuffer();
        }).then(function (buf) {
            var bytes = new Uint8Array(buf);
            for (var i = 0; i < bytes.length; i++) bytes[i] ^= key[i % key.length];
            return URL.createObjectURL(new Blob([bytes], { type: "image/gif" }));
        });
    }

    function submitForm(event, form) {
        event.preventDefault();
        showLoading(form);
        var data = new FormData(form);
        var method = (data.get("_method") || form.getAttribute("method") || "post").toLowerCase();
        data.delete("_method");
        var action = form.getAttribute("action") || "";
        var endpoint = handsBase + "/embed/hand" + (action.indexOf("/set_location") !== -1 ? "/set_location" : "");
        var httpMethod = method === "delete" ? "DELETE" : (method === "patch" ? "PATCH" : "POST");
        freshToken().then(function (token) {
            if (!token) return;
            var opts = { method: httpMethod, headers: { Authorization: "Bearer " + token } };
            if (httpMethod !== "DELETE") opts.body = data;
            return fetch(endpoint, opts).then(function (r) {
                if (r.ok) return r.text().then(render);
            });
        });
    }

    function showLoading(form) {
        var btn = form.querySelector("[type=submit]");
        if (btn && btn.dataset.loadingText) { btn.textContent = btn.dataset.loadingText; btn.disabled = true; }
    }

    function loadFragment() {
        return freshToken().then(function (token) {
            if (!token) return;
            return fetch(handsBase + "/embed/hand", { headers: { Authorization: "Bearer " + token } })
                .then(function (r) { if (r.ok) return r.text().then(render); });
        });
    }

    // Minimal Action Cable client: subscribe to WidgetChannel for live updates
    // (which also records "widget open" presence) and heartbeat to stay present.
    function openCable() {
        freshToken().then(function (token) {
            if (!token) return;
            var ws = new WebSocket(handsBase.replace(/^http/, "ws") + "/cable?token=" + encodeURIComponent(token));
            var identifier = JSON.stringify({ channel: "WidgetChannel", source_label: "embed" });
            var heartbeat;

            ws.addEventListener("message", function (ev) {
                var msg = JSON.parse(ev.data);
                if (msg.type === "welcome") {
                    ws.send(JSON.stringify({ command: "subscribe", identifier: identifier }));
                } else if (msg.type === "confirm_subscription") {
                    heartbeat = setInterval(function () {
                        ws.send(JSON.stringify({ command: "message", identifier: identifier, data: JSON.stringify({ action: "appear" }) }));
                    }, 30000);
                } else if (msg.message && msg.message.html) {
                    render(msg.message.html);
                }
            });
            ws.addEventListener("close", function () {
                clearInterval(heartbeat);
                setTimeout(openCable, 3000); // reconnect with a fresh token
            });
        });
    }

    loadFragment().then(openCable);
})();
