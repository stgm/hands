<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hands" %></title>
    <%# interactive-widget=resizes-content makes the on-screen keyboard shrink
        the layout viewport (and thus body.mini-app's 100dvh) instead of just
        overlaying on top of it, so .mini-app-body reflows/scrolls to keep
        the focused field visible rather than being covered. %>
    <meta name="viewport" content="width=device-width,initial-scale=1,interactive-widget=resizes-content">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hands">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#F4F9FF">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# The "mini app" shell: a full-screen app on phones, a framed card on desktop.
      No navbar — navigation lives in the top-level menu at the root path. %>
  <body class="mini-app" data-controller="navigation">
    <div class="mini-app-container <%= "wide" if content_for?(:wide) %> <%= yield :container_class %>" <%= yield :container_data %>>
      <% unless content_for?(:no_header) %>
        <div class="mini-app-header">
          <%# With no navbar, the header icon is the way back. It navigates browser
              history (via the "navigation" controller); root_path is just the
              plain-link fallback for a fresh tab with no history to go back to. %>
          <%= link_to (content_for?(:app_icon) ? yield(:app_icon) : "✋"), root_path,
                class: "icon text-decoration-none", title: "Back",
                data: { action: "click->navigation#back" } %>
          <h1><%= content_for?(:app_title) ? yield(:app_title) : (content_for(:title) || "Hands") %></h1>
          <h3 class="text-body-secondary"><%= yield :app_subtitle %></h3>
        </div>
      <% end %>

      <% if flash.any? %>
        <div class="mini-app-flash">
          <%= render "layouts/flash" %>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
