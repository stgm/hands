<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hands" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hands">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#F4F9FF">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# The "mini app" shell: a full-screen app on phones, a framed card on desktop.
      No navbar — navigation lives in the top-level menu at the root path. %>
  <body class="mini-app">
    <div class="mini-app-container <%= "wide" if content_for?(:wide) %>">
      <div class="mini-app-header">
        <%# With no navbar, the header icon is the way back to the top-level menu. %>
        <%= link_to (content_for?(:app_icon) ? yield(:app_icon) : "✋"), root_path,
              class: "icon text-decoration-none", title: "Menu" %>
        <h1><%= content_for?(:app_title) ? yield(:app_title) : (content_for(:title) || "Hands") %></h1>
        <h3 class="text-body-secondary"><%= yield :app_subtitle %></h3>
      </div>

      <div class="mini-app-body hands-app">
        <%= render "layouts/flash" %>
        <%= yield %>
      </div>
    </div>
  </body>
</html>
