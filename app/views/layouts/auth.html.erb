<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sign in — Hands" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#F4F9FF">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# No navbar here: the mini-app grid collapses to a single full-height area. %>
  <body class="mini-app">
    <div class="mini-app-container">
      <div class="mini-app-header">
        <span class="icon">✋</span>
        <h1>Hands</h1>
        <h3 class="text-body-secondary"><%= yield :app_subtitle %></h3>
      </div>

      <div class="mini-app-body">
        <%= render "layouts/flash" %>
        <%= yield %>
      </div>
    </div>
  </body>
</html>
