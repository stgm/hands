<% content_for :title, "Request" %>
<% content_for :app_icon, "🙋" %>
<% content_for :app_title, @hand.user.display_name %>
<% content_for :app_subtitle, @hand.formatted_request_time %>

<div class="mini-app-body">
  <div class="cards">
    <div class="message">
      <div class="question">
        <h4><%= @hand.course_domain.location_type.capitalize %>:</h4>
        <p><%= @hand.location %></p>
        <h4>Request:</h4>
        <p>
          "<% if @hand.subject.present? %><strong><%= @hand.subject %></strong>&mdash;<% end %><%= @hand.help_question %>"
        </p>
      </div>
    </div>
    <div class="message">
      <p>
        <% if @hand.done? %>
          Closed by
          <%= staff_name(@hand.assist) %>
          at
          <%= @hand.closed_at %>
        <% elsif @hand.assist %>
          Picked up by <%= staff_name(@hand.assist) %>!
        <% else %>
          Waiting since
          <%= time_ago_in_words(@hand.created_at) %>.
        <% end %>
      </p>
    </div>
  </div>
</div>

<%# A closed hand has no remaining actions, so the footer is dropped entirely. %>
<% unless @hand.done? %>
  <div class="mini-app-footer">
    <% if @hand.assist.nil? %>
      <%= button_to "Start helping",
      claim_domain_queue_hand_path(current_course_domain.slug, @hand),
      method: :put,
      class: "action primary" %>
      <%= button_to "Delete",
      done_domain_queue_hand_path(current_course_domain.slug, @hand, success: false),
      method: :put,
      class: "action",
      form: {
        data: {
          controller: "back-redirect",
          turbo_confirm: "Sure to delete this request?",
        },
      } %>
    <% else %>
      <%= button_to "Done",
      done_domain_queue_hand_path(current_course_domain.slug, @hand, success: true),
      method: :put,
      class: "action primary",
      form: {
        data: {
          controller: "back-redirect",
        },
      } %>
      <%= button_to "Put back",
      helpline_domain_queue_hand_path(current_course_domain.slug, @hand),
      method: :put,
      class: "action",
      form: {
        data: {
          controller: "back-redirect",
          turbo_confirm: "Are you sure someone is available for extra help?",
        },
      } %>
      <%= button_to "Delete",
      done_domain_queue_hand_path(current_course_domain.slug, @hand, success: false),
      method: :put,
      class: "action",
      form: {
        data: {
          controller: "back-redirect",
          turbo_confirm: "Sure to delete this request?",
        },
      } %>
    <% end %>
  </div>
<% end %>
