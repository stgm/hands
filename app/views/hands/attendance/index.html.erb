<% content_for :title, "All students — #{current_course_domain.name}" %>
<% content_for :app_icon, "👀" %>
<% content_for :app_title, "All students" %>
<% content_for :app_subtitle, "#{current_course_domain.name} — #{@presences_by_membership.size} with the widget open" %>

<%= turbo_stream_from current_course_domain, :attendance %>

<% content_for :container_data do %>data-controller="filter"<% end %>

<div id="attendance" class="attendance" data-filter-target="grid">
  <%= render "hands/attendance/grid", students: @students, presences_by_membership: @presences_by_membership, course_domain: current_course_domain %>
</div>

<% content_for :footer do %>
  <input type="text" class="form-control attendance-filter"
         placeholder="Filter students…" aria-label="Filter students"
         data-filter-target="input" data-action="input->filter#apply">
<% end %>
