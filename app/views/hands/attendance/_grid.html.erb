<% if students.any? %>
  <div class="row row-cols-2 g-3 attendance-grid">
    <% students.each do |student| %>
      <% presences = presences_by_membership[student.id] || [] %>
      <% present = presences.any? %>
      <div class="col" data-filter-name="<%= student.display_name.downcase %>">
        <div class="card student-card <%= "student-card--present" if present %>">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2">
              <h6 class="card-title mb-1">
                <%= link_to student.display_name,
                      domain_student_notes_path(course_domain.slug, student.id),
                      class: "text-decoration-none text-reset stretched-link" %>
              </h6>
              <span class="status-dot <%= present ? "status-dot--present" : "status-dot--away" %>"></span>
            </div>
            <% if present %>
              <% presences.each do |presence| %>
                <div class="small text-body-secondary">
                  <%= presence.location.presence || course_domain.location_type.to_s.capitalize %>
                  <span class="badge bg-light text-dark"><%= presence.source_label.presence || "direct" %></span>
                  · <%= time_ago_in_words(presence.connected_at) %> ago
                </div>
              <% end %>
            <% else %>
              <div class="small text-body-secondary">Not here</div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <div class="message attendance-empty-filter" hidden>
    <h5>No students match that filter.</h5>
  </div>
<% else %>
  <div class="message"><h5>No students in this course yet.</h5></div>
<% end %>
