<% students.each do |student| %>
  <% presences = presences_by_membership[student.id] || [] %>
  <% present = presences.any? %>
  <li data-filter-name="<%= student.display_name.downcase %>">
    <%= link_to domain_student_notes_path(course_domain.slug, student.id),
          class: "student-card #{"student-card--present" if present}" do %>
      <div class="d-flex justify-content-between align-items-start gap-2">
        <h6 class="card-title mb-1"><%= student.display_name %></h6>
        <span class="status-dot <%= present ? "status-dot--present" : "status-dot--away" %>" aria-hidden="true"></span>
      </div>
      <% if present %>
        <% presences.each do |presence| %>
          <div class="small text-body-secondary">
            <%= presence.location.presence || course_domain.location_type.to_s.capitalize %>
            <span class="badge bg-light text-dark"><%= presence.source_label.presence || "direct" %></span>
            · <%= time_ago_in_words(presence.connected_at) %> ago
          </div>
        <% end %>
      <% else %>
        <div class="small text-body-secondary">Not here</div>
      <% end %>
    <% end %>
  </li>
<% end %>
