<% content_for :title, "#{@membership.display_name} — Notes — #{current_course_domain.name}" %>
<% content_for :wide, false %>
<% content_for :app_icon, "📝" %>
<% content_for :app_title, @membership.display_name %>
<% content_for :app_subtitle, "#{current_course_domain.name}" %>

<div class="mini-app-body hands-app notes-page" data-controller="chat" data-action="disclosure:toggle@window->chat#scrollToBottom" data-chat-target="messages">
  <ul class="notes-list"><% @notes.each do |note| -%>
    <li class="note-item">
      <% if note.author %>
        <div class="note-author"><%= note.author.display_name %></div>
      <% end %>
      <div class="note-bubble"><%= note.text %></div>
      <div class="note-time"><%= note.created_at.strftime("%-d %b %H:%M") %></div>
    </li>
  <% end -%></ul>
</div>

<div class="mini-app-footer notes-chat-composer" data-controller="disclosure">
    <div data-disclosure-target="content" hidden class="add-note-form">
      <%= form_with url: domain_notes_path(current_course_domain.slug), method: :post do |f| %>
        <%= hidden_field_tag :membership_id, @membership.id %>
        <div class="note-field">
          <%= f.rich_text_area :text, required: true %>
        </div>
        <div class="note-form-actions">
          <%= f.button "Save note", class: "note-submit" %>
        </div>
      <% end %>
    </div>

    <button type="button" class="note-toggle-btn" data-disclosure-target="trigger" data-action="disclosure#toggle">
      +
    </button>
</div>
