<% content_for :title, "Recent notes — #{current_course_domain.name}" %>
<% content_for :wide, false %>
<% content_for :app_icon, "📝" %>
<% content_for :app_title, "Recent notes" %>
<% content_for :app_subtitle, "#{current_course_domain.name}" %>

<div class="mini-app-body hands-app notes-page recent-notes-page" data-controller="chat" data-chat-target="messages">
  <ul class="notes-list">
    <% @notes.chunk_while { |a, b| a.membership_id == b.membership_id }.each do |group| %>
      <li class="note-group-heading">
        <%= link_to group.first.membership.display_name,
              domain_student_notes_path(current_course_domain.slug, group.first.membership_id) %>
      </li>
      <% group.each do |note| %>
        <li class="note-item">
          <% if note.author %>
            <div class="note-author"><%= note.author.display_name %></div>
          <% end %>
          <div class="note-bubble"><%= note.text %></div>
          <div class="note-time"><%= note.created_at.strftime("%-d %b %H:%M") %></div>
        </li>
      <% end %>
    <% end %>
  </ul>
</div>
