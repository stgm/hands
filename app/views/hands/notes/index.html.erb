<% content_for :title, "Recent notes — #{current_course_domain.name}" %>
<% content_for :wide, false %>
<% content_for :app_icon, "📝" %>
<% content_for :app_title, "Recent notes" %>
<% content_for :app_subtitle, "#{current_course_domain.name}" %>

<% if @notes.any? %>
  <ul class="list-group">
    <% @notes.each do |note| %>
      <li class="list-group-item">
        <div class="d-flex justify-content-between">
          <%= link_to note.membership.display_name,
                domain_student_notes_path(current_course_domain.slug, note.membership_id),
                class: "fw-bold text-decoration-none" %>
          <span class="small text-body-secondary"><%= note.created_at.strftime("%-d %b %H:%M") %></span>
        </div>
        <div><%= note.text %></div>
        <% if note.author %><div class="small text-body-secondary">— <%= note.author.display_name %></div><% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-body-secondary">No notes yet.</p>
<% end %>
