<% content_for :title, "Course domains" %>
<% content_for :wide, false %>
<% content_for :app_icon, "🏫" %>
<% content_for :app_title, "Course domains" %>
<% content_for :app_subtitle, "Site administration" %>

<div class="mini-app-body hands-app">
  <% if @course_domains.any? %>
    <div class="list-group">
      <% @course_domains.each do |domain| %>
        <div class="list-group-item list-group-item-action d-flex align-items-stretch p-0">
          <%= link_to edit_admin_course_domain_path(domain), class: "flex-grow-1 p-3 text-decoration-none text-reset" do %>
            <div class="fw-bold"><%= domain.name %></div>
            <div class="small text-body-secondary">
              <code><%= domain.slug %></code> · <%= domain.enrollment_open? ? "Open" : "Closed" %> · <%= pluralize(domain.memberships.count, "member") %>
            </div>
          <% end %>
          <%= link_to "Open", domain_root_path(domain.slug),
                class: "d-flex align-items-center px-3 border-start text-decoration-none flex-shrink-0" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-body-secondary">No course domains yet.</p>
  <% end %>
</div>

<div class="mini-app-footer">
  <%= link_to "New course domain", new_admin_course_domain_path, class: "action primary" %>
</div>
