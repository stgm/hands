<% content_for :title, "Course domains" %>
<% content_for :app_icon, "🏫" %>
<% content_for :app_title, "Course domains" %>
<% content_for :app_subtitle, "Site administration" %>

<div class="mini-app-body hands-app">
  <% if @course_domains.any? %>
    <ul class="menu">
      <% @course_domains.each do |domain| %>
        <li>
          <%= link_to domain_root_path(domain.slug) do %>
            <div class="list-item__title"><%= domain.name %></div>
            <div class="small text-muted">
              <code><%= domain.slug %></code> · <%= domain.enrollment_open? ? "Open" : "Closed" %> · <%= pluralize(domain.memberships.count, "member") %>
            </div>
          <% end %>
          <%= link_to "Edit", edit_admin_course_domain_path(domain) %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted">No course domains yet.</p>
  <% end %>
</div>

<div class="mini-app-footer">
  <%= link_to "New course domain", new_admin_course_domain_path, class: "action primary" %>
</div>
