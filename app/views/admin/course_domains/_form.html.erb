<%= form_with model: @course_domain, url: form_url do |f| %>
  <% if @course_domain.errors.any? %>
    <div class="alert alert--danger"><%= @course_domain.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="mb-3">
    <%= f.label :name %>
    <%= f.text_field :name, required: true %>
  </div>
  <div class="mb-3">
    <%= f.label :location_type, "Location label (e.g. table, room)" %>
    <%= f.text_field :location_type %>
  </div>
  <div class="mb-3">
    <%= f.label :locale, "Language" %>
    <%= f.select :locale, I18n.available_locales.map { |l| [ l.to_s.upcase, l ] } %>
    <div class="hint">Used for the standalone widget. A linked course-site hands over its own language for the embedded widget.</div>
  </div>
  <div class="field-check">
    <%= f.check_box :enrollment_open %>
    <%= f.label :enrollment_open, "Allow students to self-join via the domain link" %>
  </div>

  <fieldset class="field-group">
    <legend class="h6">Student widget</legend>
    <div class="field-check">
      <%= f.check_box :ask_location %>
      <%= f.label :ask_location, "Ask for a location when raising a hand" %>
    </div>
    <div class="field-check">
      <%= f.check_box :location_bumper %>
      <%= f.label :location_bumper, "Check students in (ask location before anything else)" %>
    </div>
    <div class="field-check">
      <%= f.check_box :link_mode %>
      <%= f.label :link_mode, "Ask for a Zoom link instead of a physical location" %>
    </div>
  </fieldset>

  <%= f.submit class: "btn btn--primary" %>
<% end %>
