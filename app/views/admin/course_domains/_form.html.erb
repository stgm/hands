<%= form_with model: @course_domain, url: form_url do |f| %>
  <% if @course_domain.errors.any? %>
    <div class="alert alert-danger"><%= @course_domain.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, required: true, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :location_type, "Location label (e.g. table, room)", class: "form-label" %>
    <%= f.text_field :location_type, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :locale, "Language", class: "form-label" %>
    <%= f.select :locale, I18n.available_locales.map { |l| [ l.to_s.upcase, l ] }, {}, class: "form-select" %>
    <div class="form-text">Used for the standalone widget. A linked course-site hands over its own language for the embedded widget.</div>
  </div>
  <div class="form-check mb-2">
    <%= f.check_box :enrollment_open, class: "form-check-input" %>
    <%= f.label :enrollment_open, "Allow students to self-join via the domain link", class: "form-check-label" %>
  </div>

  <fieldset class="border rounded p-3 mb-3">
    <legend class="h6">Student widget</legend>
    <div class="form-check mb-2">
      <%= f.check_box :ask_location, class: "form-check-input" %>
      <%= f.label :ask_location, "Ask for a location when raising a hand", class: "form-check-label" %>
    </div>
    <div class="form-check mb-2">
      <%= f.check_box :location_bumper, class: "form-check-input" %>
      <%= f.label :location_bumper, "Check students in (ask location before anything else)", class: "form-check-label" %>
    </div>
    <div class="form-check mb-2">
      <%= f.check_box :link_mode, class: "form-check-input" %>
      <%= f.label :link_mode, "Ask for a Zoom link instead of a physical location", class: "form-check-label" %>
    </div>
  </fieldset>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
